# C.O.R.A. - variaveis para deploy no Railway
# Cole no RAW Editor do service principal no Railway e troque os placeholders.
# Se voce usar o formulario chave/valor do Railway, coloque so o valor no campo Value.
# Exemplo correto: key=REDIS_PORT, value=11737

# Runtime do backend
FIREBASE_PROJECT_ID=cora-9d120
FIREBASE_STORAGE_BUCKET=cora-9d120.firebasestorage.app
FIREBASE_FIRESTORE_DATABASE_ID=(default)
FIREBASE_ALLOWED_PROJECT_IDS=cora-9d120
FIREBASE_SERVICE_ACCOUNT_JSON=<JSON_EM_LINHA_UNICA_DA_SERVICE_ACCOUNT_FIREBASE>

GEMINI_API_KEY=<SUA_GEMINI_API_KEY>
GOOGLE_API_KEY=<MESMO_VALOR_DA_GEMINI_API_KEY_OPCIONAL>

PINECONE_API_KEY=<SUA_PINECONE_API_KEY>
PINECONE_NAMESPACE=notas_conflito_interesse
PINECONE_TOP_K=10
PINECONE_SIMILARITY_THRESHOLD=0.3
PINECONE_FINAL_RESULT_COUNT=10
PINECONE_CONTEXT_EXCERPT_CHARS=2200

REDIS_HOST=<HOST_DO_REDIS>
REDIS_PORT=<PORTA_DO_REDIS>
REDIS_PASSWORD=<SENHA_DO_REDIS>
REDIS_DB=0
REDIS_CONTEXT_MAX_MESSAGES=3
REDIS_RETRIEVAL_USER_TURNS=2

# Recomendado em producao
CORS_ORIGINS=https://SEU_DOMINIO_PUBLICO_DO_RAILWAY

# Opcional
PUBLIC_LOCAL_HOST=localhost
FRONTEND_URL=

# Variaveis publicas do Firebase Web
# No deploy atual com o Dockerfile da raiz, o frontend ja usa frontend/.env.production do repositorio.
# Mantenha aqui apenas como referencia caso voce queira externalizar a configuracao depois.
REACT_APP_FIREBASE_API_KEY=<FIREBASE_WEB_API_KEY>
REACT_APP_FIREBASE_AUTH_DOMAIN=cora-9d120.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=cora-9d120
REACT_APP_FIREBASE_STORAGE_BUCKET=cora-9d120.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=<FIREBASE_MESSAGING_SENDER_ID>
REACT_APP_FIREBASE_APP_ID=<FIREBASE_APP_ID>
REACT_APP_FIREBASE_APP_NAME=cora-web
